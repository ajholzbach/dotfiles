{{- if and (or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux")) (lookPath "fish") -}}
#!/usr/bin/env bash
set -euo pipefail

# fish_plugins_sha256={{ include "dot_config/fish/fish_plugins" | sha256sum }}
# fish_theme_sha256={{ include "dot_config/fish/themes/Catppuccin Mocha.theme" | sha256sum }}

if ! command -v curl >/dev/null 2>&1; then
    echo "Error: curl is required to install Fisher"
    exit 1
fi

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CONFIG_HOME

FISH_FUNCTIONS_DIR="$XDG_CONFIG_HOME/fish/functions"
FISHER_FUNCTION="$FISH_FUNCTIONS_DIR/fisher.fish"
FISH_PLUGINS="$XDG_CONFIG_HOME/fish/fish_plugins"
FISH_COMPLETIONS_DIR="$XDG_CONFIG_HOME/fish/completions"

move_unmanaged_fisher_install_conflict() {
    local plugin="$1"
    local target="$2"

    if [ ! -f "$target" ] && [ ! -L "$target" ]; then
        return 0
    fi

    if fish -c 'contains -- $argv[1] $_fisher_plugins' "$plugin" >/dev/null 2>&1; then
        return 0
    fi

    if fish -c '
        set --local plugin_files_var _fisher_(string escape --style=var -- $argv[1])_files
        set --local tilde_target (string replace -- $HOME \~ $argv[2])
        contains -- $argv[2] $$plugin_files_var || contains -- $tilde_target $$plugin_files_var
    ' "$plugin" "$target" >/dev/null 2>&1; then
        return 0
    fi

    local backup="${target}.pre-fisher-backup"
    local index=0
    while [ -e "$backup" ] || [ -L "$backup" ]; do
        index=$((index + 1))
        backup="${target}.pre-fisher-backup.${index}"
    done

    echo "Moving unmanaged Fish completion that conflicts with first install of $plugin to $backup..."
    mv "$target" "$backup"
}

if ! fish -c 'functions -q fisher' >/dev/null 2>&1; then
    mkdir -p "$FISH_FUNCTIONS_DIR"
    echo "Installing Fisher plugin manager..."
    curl -fsSL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish -o "$FISHER_FUNCTION"
fi

if [ -f "$FISH_PLUGINS" ] && grep -Fxq "ajholzbach/fish-kubectl" "$FISH_PLUGINS"; then
    move_unmanaged_fisher_install_conflict \
        "ajholzbach/fish-kubectl" \
        "$FISH_COMPLETIONS_DIR/kubectl.fish"
fi

# fish_plugins has already been applied by chezmoi at this point; fisher reads it directly
echo "Syncing Fish plugins..."
fish -c 'fisher update'

if [ -f "$XDG_CONFIG_HOME/fish/themes/Catppuccin Mocha.theme" ]; then
    if fish -c 'fish_config theme list >/dev/null 2>&1'; then
        echo "Applying Fish theme..."
        fish -c 'echo y | fish_config theme save "Catppuccin Mocha" >/dev/null'
    fi
fi
{{- end }}
