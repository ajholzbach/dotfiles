{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash
set -euo pipefail

# One-time migration of pre-local-env machines: copy ~/.bash_profile to
# ~/.config/local-env.sh (mode 600). Original .bash_profile is left in place
# for manual review and removal

LOCAL_ENV="$HOME/.config/local-env.sh"
BASH_PROFILE="$HOME/.bash_profile"

[ -f "$LOCAL_ENV" ] && exit 0
[ ! -f "$BASH_PROFILE" ] && exit 0

mkdir -p "$(dirname "$LOCAL_ENV")"
install -m 600 "$BASH_PROFILE" "$LOCAL_ENV"
echo "Migrated ~/.bash_profile -> $LOCAL_ENV (mode 600)."
echo "Review the file, then remove the original with: rm ~/.bash_profile"
{{- end }}
